# Alpaca Trading API Configuration
# Get your API keys from: https://docs.alpaca.markets/docs/getting-started-with-trading-api

# Alpaca API Key (Key ID)
ALPACA_API_KEY=your_alpaca_api_key_here

# Alpaca Secret Key
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper Trading Mode (true/false)
# Set to true for paper trading (simulated), false for live trading
ALPACA_PAPER=true
